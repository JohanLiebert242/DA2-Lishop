{
  "name": "lishop-frontend",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --concurrency=11",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "e2e:checkout": "pnpm dlx @playwright/test test -c playwright.config.ts tests/e2e/checkout.spec.ts",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.0.0",
    "eslint": "^9.9.0",
    "eslint-config-next": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "webpack": "^5.90.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
